# Environment Configuration for MyReactNativeApp

# Backend API Configuration
API_BASE_URL=http://10.0.0.150:3000/api
API_TIMEOUT=10000

# Weather API Configuration
# Get your free API key from https://openweathermap.org/api
OPENWEATHER_API_KEY=YOUR_API_KEY_HERE

# Database Configuration (for backend)
MONGODB_URI=mongodb://localhost:27017/agriculture-app
JWT_SECRET=your-secret-key

# React Native Configuration
# For Android Emulator: use 10.0.2.2
# For iOS Simulator: use 192.168.1.89
# For Physical Device: use computer's IP address
REACT_NATIVE_API_URL=http://10.0.0.174:3000/api

